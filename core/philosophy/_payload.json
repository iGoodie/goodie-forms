ct/usefieldvalue","2.react/7.useFieldValue",{"title":80,"path":81,"stem":82,"icon":39},"useFieldIssues()","/react/usefieldissues","2.react/8.useFieldIssues",{"title":84,"icon":85,"path":86,"stem":87,"children":88,"page":48},"Vue Package","uil:vuejs","/vue","3.vue",[89],{"title":90,"path":91,"stem":92,"icon":14},"WIP","/vue/introduction","3.vue/2.introduction",{"id":94,"title":16,"body":95,"description":872,"extension":873,"links":874,"meta":875,"navigation":876,"path":17,"seo":877,"stem":18,"__hash__":881},"docs/1.core/2.philosophy.md",{"type":96,"value":97,"toc":860},"minimark",[98,106,112,131,188,198,201,206,305,309,404,408,505,509,602,606,675,679,737,741,808,812],[99,100,101,105],"p",{},[102,103,104],"strong",{},"Goodie Forms"," is built on a simple premise:",[107,108,109],"blockquote",{},[99,110,111],{},"Forms are state machines — not UI framework state.",[99,113,114,118,119,122,123,126,127,130],{},[115,116,117],"em",{},"Most form libraries"," ",[102,120,121],{},"tightly couple"," their logic to a ",[102,124,125],{},"specific framework",".\nGoodie Forms does not. Instead, it ",[102,128,129],{},"separates concerns"," clearly:",[132,133,134,164],"ul",{},[135,136,137,144,145,148,149,152,153,152,156,159,160,163],"li",{},[138,139],"icon",{"className":140,"name":143},[141,142],"size-5","text-secondary","material-symbols:readiness-score-outline"," A ",[102,146,147],{},"framework-agnostic core"," handles ",[102,150,151],{},"state",", ",[102,154,155],{},"validation",[102,157,158],{},"paths",", and ",[102,161,162],{},"events",".",[135,165,166,118,170,173,174,152,177,180,181,184,185,163],{},[138,167],{"className":168,"name":169},[141,142],"tabler:layout-board-split",[102,171,172],{},"UI bindings"," (",[115,175,176],{},"React",[115,178,179],{},"Vue",", or ",[115,182,183],{},"any future adapter",") act purely as ",[102,186,187],{},"subscription layers",[99,189,190,191,194,195,163],{},"The form engine ",[102,192,193],{},"exists independently"," from how it is ",[102,196,197],{},"rendered",[199,200],"hr",{},[202,203,205],"h2",{"id":204},"headless-by-design","🧠 Headless by Design",[207,208,209,220,242,263,266,292],"doc-ref-section",{},[99,210,211,212,214,215,219],{},"At the center of ",[102,213,104],{}," is the ",[216,217,218],"code",{},"FormController",". It is:",[132,221,222,227,232,237],{},[135,223,224],{},[102,225,226],{},"Framework-independent",[135,228,229],{},[102,230,231],{},"Event-driven",[135,233,234],{},[102,235,236],{},"Deterministic",[135,238,239],{},[102,240,241],{},"Fully typed",[99,243,244,245,248,249,252,253,256,257,252,259,262],{},"It ",[102,246,247],{},"does not depend"," on hooks.\n",[250,251],"br",{},"\nIt ",[102,254,255],{},"does not assume"," a rendering model.\n",[250,258],{},[102,260,261],{},"does not mirror"," state into any framework.",[99,264,265],{},"This ensures:",[132,267,268,274,280,286],{},[135,269,270,271],{},"The core remains ",[102,272,273],{},"portable across ecosystems",[135,275,276,277],{},"Business logic is ",[102,278,279],{},"testable without UI",[135,281,282,283],{},"Behavior stays consistent ",[102,284,285],{},"regardless of rendering strategy",[135,287,288,289],{},"New framework adapters can be implemented ",[102,290,291],{},"without rewriting the engine",[99,293,294,297,298,301,302],{},[102,295,296],{},"UI integrations"," are intentionally ",[102,299,300],{},"thin bridges"," — ",[115,303,304],{},"nothing more.",[202,306,308],{"id":307},"️-the-controller-owns-the-state","🏗️ The Controller Owns the State",[207,310,311,322,353,370,388],{},[99,312,313,314,317,318,321],{},"In many ",[102,315,316],{},"form systems",", UI frameworks become the ",[102,319,320],{},"state container",". This often leads to:",[132,323,324,329,335,348],{},[135,325,326],{},[102,327,328],{},"Duplicated state",[135,330,331,332],{},"Excessive ",[102,333,334],{},"re-renders",[135,336,337,340,341,344,345],{},[102,338,339],{},"Tight coupling"," between ",[102,342,343],{},"rendering"," and ",[102,346,347],{},"data",[135,349,350],{},[102,351,352],{},"Implicit mutation flows",[99,354,355,357,358,361,362,365,366,369],{},[102,356,104],{}," flips that model. The ",[102,359,360],{},"controller"," owns ",[102,363,364],{},"the data",". ",[102,367,368],{},"Frameworks"," subscribe to it. There is:",[132,371,372,378,383],{},[135,373,374,375],{},"❌ ",[102,376,377],{},"No mirrored framework state",[135,379,374,380],{},[102,381,382],{},"No hidden synchronization layers",[135,384,374,385],{},[102,386,387],{},"No dependency on a specific rendering paradigm",[99,389,390,393,394,397,398,301,401],{},[102,391,392],{},"Rendering"," is an ",[102,395,396],{},"effect"," of ",[102,399,400],{},"subscription",[115,402,403],{},"not the driver of state.",[202,405,407],{"id":406},"️-explicit-reactivity-over-implicit-magic","🧙‍♂️ Explicit Reactivity Over Implicit Magic",[207,409,410,430,452,480,497],{},[99,411,412,415,416,419,420,423,424,365,427,429],{},[102,413,414],{},"Magic abstractions"," feel productive ",[102,417,418],{},"early on",". They become ",[102,421,422],{},"fragile"," at ",[102,425,426],{},"scale",[102,428,104],{}," favors:",[132,431,432,437,442,447],{},[135,433,434],{},[102,435,436],{},"Explicit subscriptions",[135,438,439],{},[102,440,441],{},"Clear mutation flows",[135,443,444],{},[102,445,446],{},"Predictable event boundaries",[135,448,449],{},[102,450,451],{},"Deterministic validation timing",[99,453,454,455,152,458,461,462,464,465,152,468,461,471,473,474,152,477,163],{},"If something ",[102,456,457],{},"updates",[102,459,460],{},"you know why",".\n",[250,463],{},"\nIf validation ",[102,466,467],{},"runs",[102,469,470],{},"you know when",[250,472],{},"\nIf a ",[102,475,476],{},"component reacts",[102,478,479],{},"it does so intentionally",[132,481,482,487,492],{},[135,483,374,484],{},[102,485,486],{},"No hidden proxies.",[135,488,374,489],{},[102,490,491],{},"No implicit dependency tracking.",[135,493,374,494],{},[102,495,496],{},"No runtime heuristics.",[99,498,499,500,344,502,163],{},"Just ",[102,501,162],{},[102,503,504],{},"subscriptions",[202,506,508],{"id":507},"isolation-is-the-default","🧩 Isolation is the Default",[207,510,511,520,549,558,584,594],{},[99,512,513,118,516,519],{},[115,514,515],{},"Large forms",[102,517,518],{},"fail"," when:",[132,521,522,531,540],{},[135,523,524,527,528],{},[102,525,526],{},"State changes"," cascade ",[102,529,530],{},"unpredictably",[135,532,533,536,537],{},[102,534,535],{},"Validation leaks"," across ",[102,538,539],{},"unrelated fields",[135,541,542,545,546],{},[102,543,544],{},"Performance degrades"," as ",[102,547,548],{},"complexity grows",[99,550,551,553,554,557],{},[102,552,104],{}," isolates by ",[102,555,556],{},"architecture",". Each field:",[132,559,560,566,572,578],{},[135,561,562,563],{},"Has its ",[102,564,565],{},"own state slice",[135,567,568,569],{},"Emits ",[102,570,571],{},"scoped events",[135,573,574,575],{},"Can be ",[102,576,577],{},"observed independently",[135,579,580,581],{},"Cleans up ",[102,582,583],{},"safely when detached",[99,585,586,587,590,591,163],{},"Whether you ",[102,588,589],{},"render 3 fields or 300",", the behavior ",[102,592,593],{},"remains predictable",[99,595,596,301,599],{},[102,597,598],{},"Scalability is structural",[115,600,601],{},"not achieved through patchwork optimizations.",[202,603,605],{"id":604},"type-safety-is-structural","🔐 Type Safety is Structural",[207,607,608,631,653,666],{},[99,609,610,613,614,617,618,621,622,625,626,365,628,630],{},[102,611,612],{},"Type safety"," is ",[102,615,616],{},"not a layer"," added ",[102,619,620],{},"on top",". It is ",[102,623,624],{},"embedded"," into the ",[102,627,556],{},[102,629,104],{}," provides:",[132,632,633,638,643,648],{},[135,634,635],{},[102,636,637],{},"Deep path inference",[135,639,640],{},[102,641,642],{},"Compile-time path validation",[135,644,645],{},[102,646,647],{},"Accurate nested type resolution",[135,649,650],{},[102,651,652],{},"Strongly typed controller APIs",[99,654,655,658,659,662,663,163],{},[102,656,657],{},"Types"," guide ",[102,660,661],{},"the design"," rather than ",[102,664,665],{},"decorate it",[99,667,668,669,344,672,163],{},"This ",[102,670,671],{},"reduces runtime errors",[102,673,674],{},"eliminates entire classes of invalid state transitions",[202,676,678],{"id":677},"validation-is-a-lifecycle","🧪 Validation is a Lifecycle",[207,680,681,693,715,726],{},[99,682,683,685,686,689,690,219],{},[102,684,26],{}," is treated as a ",[102,687,688],{},"structured lifecycle",", not an ",[102,691,692],{},"incidental side-effect",[132,694,695,700,705,710],{},[135,696,697],{},[102,698,699],{},"Scheduled intentionally",[135,701,702],{},[102,703,704],{},"Triggered by explicit strategies",[135,706,707],{},[102,708,709],{},"Emitted through structured events",[135,711,712],{},[102,713,714],{},"Separated from rendering concerns",[99,716,668,717,152,720,159,723,163],{},[102,718,719],{},"avoids race conditions",[102,721,722],{},"inconsistent timing",[102,724,725],{},"duplicated validation logic",[99,727,728,730,731,301,734],{},[102,729,26],{}," becomes ",[102,732,733],{},"predictable",[115,735,736],{},"even in complex flows.",[202,738,740],{"id":739},"determinism-over-convenience","📐 Determinism Over Convenience",[207,742,743,750,767,774,796],{},[99,744,745,746,749],{},"Goodie Forms ",[102,747,748],{},"avoids patterns"," that:",[132,751,752,757,762],{},[135,753,754],{},[102,755,756],{},"Hide complexity behind convenience",[135,758,759],{},[102,760,761],{},"Duplicate state across layers",[135,763,764],{},[102,765,766],{},"Blur responsibility boundaries",[99,768,769,770,773],{},"Instead, it ",[102,771,772],{},"embraces",":",[132,775,776,781,786,791],{},[135,777,778],{},[102,779,780],{},"Single source of truth",[135,782,783],{},[102,784,785],{},"Stable controller instances",[135,787,788],{},[102,789,790],{},"Explicit APIs",[135,792,793],{},[102,794,795],{},"Event-driven updates",[99,797,798,799,461,802,804,805,163],{},"The goal is ",[102,800,801],{},"not fewer lines of code",[250,803],{},"\nThe goal is ",[102,806,807],{},"fewer surprises",[202,809,811],{"id":810},"framework-agnostic-by-architecture","🌍 Framework-Agnostic by Architecture",[207,813,814,823,846],{},[99,815,816,817,613,820,773],{},"Because ",[102,818,819],{},"the engine",[102,821,822],{},"independent",[132,824,825,831,836,841],{},[135,826,827,828],{},"It can ",[102,829,830],{},"power multiple UI bindings",[135,832,827,833],{},[102,834,835],{},"be tested without rendering",[135,837,827,838],{},[102,839,840],{},"run outside component trees",[135,842,827,843],{},[102,844,845],{},"integrate with non-UI workflows",[99,847,848,613,851,461,854,613,857,163],{},[102,849,850],{},"The UI layer",[102,852,853],{},"optional",[102,855,856],{},"The state machine",[102,858,859],{},"fundamental",{"title":861,"searchDepth":862,"depth":862,"links":863},"",2,[864,865,866,867,868,869,870,871],{"id":204,"depth":862,"text":205},{"id":307,"depth":862,"text":308},{"id":406,"depth":862,"text":407},{"id":507,"depth":862,"text":508},{"id":604,"depth":862,"text":605},{"id":677,"depth":862,"text":678},{"id":739,"depth":862,"text":740},{"id":810,"depth":862,"text":811},"The architectural principles behind Goodie Forms","md",null,{},{"icon":19},{"title":878,"description":879},"Goodie Forms Philosophy — Headless, Event-Driven Form Architecture",{"Discover the philosophy behind Goodie Forms":880},"a framework-agnostic, headless form state engine built on explicit reactivity, structural type safety, deterministic validation, and scalable architecture.","QWLAn0NhabDM2aDsl9d8SF_rgVIv8dx5LmVw6LDYjz4",[883,885],{"title":11,"path":12,"stem":13,"description":884,"icon":14,"children":-1},"Welcome to Goodie Forms documentation.",{"title":21,"path":22,"stem":23,"description":886,"icon":24,"children":-1},"Get started with headless Goodie Forms core.",1772224987016]