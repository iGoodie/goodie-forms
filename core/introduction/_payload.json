/react/usefieldvalue","2.react/7.useFieldValue",{"title":80,"path":81,"stem":82,"icon":39},"useFieldIssues()","/react/usefieldissues","2.react/8.useFieldIssues",{"title":84,"icon":85,"path":86,"stem":87,"children":88,"page":48},"Vue Package","uil:vuejs","/vue","3.vue",[89],{"title":90,"path":91,"stem":92,"icon":14},"WIP","/vue/introduction","3.vue/2.introduction",{"id":94,"title":11,"body":95,"description":249,"extension":250,"links":251,"meta":252,"navigation":253,"path":12,"seo":254,"stem":13,"__hash__":256},"docs/1.core/2.introduction.md",{"type":96,"value":97,"toc":243},"minimark",[98,113,118,123,126,155,159,224],[99,100,101,102,112],"p",{},"Welcome to ",[103,104,108],"a",{"href":105,"rel":106},"https://github.com/iGoodie/goodie-forms",[107],"nofollow",[109,110,111],"strong",{},"Goodie Forms",", an unopinionated modern form state and data management library.",[114,115,117],"h2",{"id":116},"what-is-goodie-forms","What is Goodie Forms?",[99,119,120,122],{},[109,121,111],{}," provides type-safe and feature-rich pieces to help you build a seamless form experience.\nIt is built from ground up, with a concern of DX (Developer Experience) in mind.",[99,124,125],{},"It is enriched and generified using these:",[127,128,129,137,143,149],"card-group",{},[130,131,136],"card",{"icon":132,"target":133,"title":134,"to":135},"goodie:brand-standardschema","\\_blank","Standard Schema","https://standardschema.dev/","A common interface for TypeScript validation libraries. Makes Goodie Forms validation library agnostic.",[130,138,142],{"icon":139,"target":133,"title":140,"to":141},"skill-icons:typescript","Typescript","https://www.typescriptlang.org/","A strongly typed programming language that builds on JavaScript. Supercharges Goodie Forms with type-safety and IntelliSense suggestions.",[130,144,148],{"icon":145,"target":133,"title":146,"to":147},"goodie:brand-immer","Immer","https://immerjs.github.io/immer/","A tiny package that allows you to work with immutable state. Makes Goodie Forms data immutable and performant to work with.",[130,150,154],{"icon":151,"target":133,"title":152,"to":153},"goodie:brand-evilmartians","Nano Events","https://github.com/ai/nanoevents","Simple and tiny event emitter library for JavaScript. Gives Goodie Forms power to emit and listen to certain events.",[114,156,158],{"id":157},"key-features","Key Features",[160,161,162,169,179,206,212,218],"ul",{},[163,164,165,168],"li",{},[109,166,167],{},"Framework-agnostic core",": Designed to work with any UI layer (React, Vue, Solid, or vanilla).",[163,170,171,174,175,178],{},[109,172,173],{},"Fully type-safe",": Built with ",[103,176,140],{"href":141,"rel":177},[107]," from the ground up. Deep type inference ensures form values, errors, and validation are correctly typed at every level.",[163,180,181,184,185,188,189,194,195,194,200,205],{},[109,182,183],{},"Validation library agnostic",": Thanks to ",[103,186,134],{"href":135,"rel":187},[107],", you can plug in popular libraries like ",[103,190,193],{"href":191,"rel":192},"https://zod.dev/",[107],"Zod",", ",[103,196,199],{"href":197,"rel":198},"https://valibot.dev/",[107],"Valibot",[103,201,204],{"href":202,"rel":203},"https://github.com/jquense/yup",[107],"Yup",", or your own validation logic without being locked into a single solution.",[163,207,208,211],{},[109,209,210],{},"Fine-grained control over state",": Track touched, dirty, validating, and error states per field or per form.",[163,213,214,217],{},[109,215,216],{},"Optimized for DX",": Clear APIs, strong IntelliSense support, and predictable behavior reduce cognitive load during development.",[163,219,220,223],{},[109,221,222],{},"Unopinionated by default",": No forced UI components. No design constraints. Goodie Forms handles logic — you handle presentation.",[127,225,226,231,237],{},[130,227,230],{"icon":228,"target":133,"title":229,"to":105},"mdi:github","Goodie Forms - GitHub Monorepo","GitHub repository that hosts the source code of Goodie Forms and its subpackages.",[130,232,236],{"icon":233,"target":133,"title":234,"to":235},"material-symbols:heart-plus","Support the Author","https://github.com/sponsors/iGoodie","If you find Goodie Forms useful, consider supporting its development through GitHub Sponsors.",[130,238,242],{"icon":239,"target":133,"title":240,"to":241},"mdi:discord","Discord Server Invite","https://discord.gg/KNxxdvN","Invite to the Discord Server",{"title":244,"searchDepth":245,"depth":245,"links":246},"",2,[247,248],{"id":116,"depth":245,"text":117},{"id":157,"depth":245,"text":158},"Welcome to Goodie Forms documentation.","md",null,{},{"icon":14},{"title":11,"description":255},"Discover Goodie Forms, a modern TypeScript form state and data management library. Framework-agnostic, validation-agnostic, and built for full control, performance, and developer experience.","FAGqISDtAmdB5-0fznEyilE0pK3ePdPWiHzPnAn2NlA",[251,258],{"title":16,"path":17,"stem":18,"description":259,"icon":19,"children":-1},"The architectural principles behind Goodie Forms",1772227432160]